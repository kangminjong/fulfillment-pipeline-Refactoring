# =========================
# Postgres
# =========================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fulfillment
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin 

# FastAPI backend (DB URL)
DATABASE_URL=postgresql://admin:admin@postgres:5432/fulfillment

# =========================
# Kafka
# =========================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=event
KAFKA_GROUP_ID=order-reader

# (옵션) consumer 설정
AUTO_OFFSET_RESET=earliest
POLL_TIMEOUT=2.0
COMMIT_EVERY_N=1

# =========================
# Slack (optional)
# =========================
ENABLE_SLACK=false
SLACK_WEBHOOK_URL=

# =========================
# Risk thresholds (optional)
# =========================
USER_BURST_WINDOW=10
USER_BURST_LIMIT=5
PROD_BURST_WINDOW=10
PROD_BURST_LIMIT=5

# =========================
# Metrics rollup (optional)
# =========================
ENABLE_METRICS_ROLLUP=0
ROLLUP_CHECK_INTERVAL_SEC=60
ROLLUP_BUCKET_MIN=30

# =========================
# Misc
# =========================
APP_TZ=Asia/Seoul